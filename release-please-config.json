{
  "$schema": "https://raw.githubusercontent.com/googleapis/release-please/main/schemas/config.json",
  "release-type": "rust",
  "packages": {
    "crates/mirufm": {
      "component": "mirufm"
    },
    "crates/mirufm-core": {
      "component": "mirufm-core"
    }
  },
  "plugins": [
    {
      "type": "cargo-workspace",
      "merge": false
    },
    {
      "type": "linked-versions",
      "groupName": "mirufm",
      "components": ["mirufm", "mirufm-core"]
    }
  ]
}
